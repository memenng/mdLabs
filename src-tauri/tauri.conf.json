{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdLabs",
  "version": "1.4.0",
  "identifier": "com.mmnlabs.mdlabs",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mdLabs",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/mdlabs.icns"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzOTlDQUUwMjdFNDEyRjQKUldUMEV1UW40TXFabys0R2huZlBFN0RGdFgraGozNlBqOXc5ay9HczZxNzdsL2dNNkQwNmx0TDQK",
      "endpoints": [
        "https://updates.mdlabs.example.com/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
